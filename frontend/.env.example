# Копирай като .env в същата папка (frontend/) и попълни стойностите.
# След промяна в .env задължително рестартирай: npm run dev

# API на бекенда (по подразбиране е http://localhost:8080)
# VITE_API_URL=http://localhost:8080
# За тест от телефон в същата Wi‑Fi: VITE_API_URL=http://<IPv4-на-PC>:8080 (виж docs/ТЕСТ_ОТ_ТЕЛЕФОН.md)
# С мобилни данни: тунел към бекенда, напр. VITE_API_URL=https://....ngrok-free.app (docs/ТЕСТ_ПРЕЗ_ТУНЕЛ.md)

# Stripe – Publishable key от https://dashboard.stripe.com/test/apikeys (Test mode)
VITE_STRIPE_PUBLISHABLE_KEY=pk_test_xxxxxxxxxxxxxxxxxxxxxxxx
